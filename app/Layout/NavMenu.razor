@inject AuthService Auth
@inject NavigationManager Navigation
@inject ApiClient ApiClient
@inject UserSettingsService Settings
@implements IDisposable

<aside class="sidebar">
    <div class="brand">Good Deeds Tracker</div>
    <button class="nav-toggle" type="button" @onclick="ToggleNavMenu">Menu</button>
    @if (_authUser is not null)
    {
        <div class="muted small">
            Signed in as
            <div class="auth-user">@_authUser.DisplayName</div>
            <div>@(_authUser.Email ?? _authUser.UserDetails)</div>
        </div>
    }
    <nav class="nav @(collapseNavMenu ? "collapsed" : string.Empty)">
        <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Dashboard</NavLink>
        <NavLink class="nav-link" href="children">Children</NavLink>
        @if (_children.Count > 0)
        {
            <div class="nav-children">
                @foreach (var child in _children)
                {
                    <NavLink class="nav-link nav-child" href="@($"children/{child.Id}")">@child.Name</NavLink>
                }
            </div>
        }
        <NavLink class="nav-link" href="deeds">Deed Types</NavLink>
        <NavLink class="nav-link" href="redeems">Redeem Types</NavLink>
        <NavLink class="nav-link" href="profile">Profile</NavLink>
        <NavLink class="nav-link" href="settings">Settings</NavLink>
    </nav>
    <div class="auth-block">
        @if (_authUser is null)
        {
            <a class="btn btn-outline-primary w-100" href="@LoginUrl">Sign in with Microsoft</a>
        }
        else
        {
            <a class="signout" href="@LogoutUrl">Sign out</a>
        }
    </div>
</aside>

@code {
    private bool collapseNavMenu = true;
    private AuthUser? _authUser;
    private readonly List<ChildDto> _children = [];
    private bool _loadingChildren;

    protected override async Task OnInitializedAsync()
    {
        Auth.UserChanged += OnAuthChanged;
        _authUser = await Auth.GetUserAsync();
        await LoadChildrenAsync();
    }

    private void OnAuthChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _authUser = await Auth.GetUserAsync();
            await LoadChildrenAsync();
            StateHasChanged();
        });
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task LoadChildrenAsync()
    {
        if (_loadingChildren)
        {
            return;
        }

        _loadingChildren = true;
        _children.Clear();
        var parentId = await Settings.GetParentIdAsync();
        if (!parentId.HasValue)
        {
            _loadingChildren = false;
            return;
        }

        try
        {
            var children = await ApiClient.GetChildrenAsync(parentId.Value);
            var seen = new HashSet<Guid>();
            foreach (var child in children)
            {
                if (seen.Add(child.Id))
                {
                    _children.Add(child);
                }
            }
        }
        catch
        {
            // Sidebar should not block rendering if children fail to load.
        }
        finally
        {
            _loadingChildren = false;
        }
    }

    private string LoginUrl => $"/.auth/login/aad?post_login_redirect_uri={Uri.EscapeDataString(ReturnPath)}";

    private string LogoutUrl => $"/.auth/logout?post_logout_redirect_uri={Uri.EscapeDataString(ReturnPath)}";

    private string ReturnPath
    {
        get
        {
            var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
            if (string.IsNullOrWhiteSpace(relative))
            {
                return "/";
            }

            return relative.StartsWith('/') ? relative : $"/{relative}";
        }
    }

    public void Dispose()
    {
        Auth.UserChanged -= OnAuthChanged;
    }
}
