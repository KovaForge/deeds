@page "/children/{ChildId:guid}"

@using System.Diagnostics
@inject ApiClient ApiClient
@inject AuthService Auth
@inject UserSettingsService Settings
@inject NavigationManager Navigation

<PageTitle>Child Profile</PageTitle>

<div class="page">
    @if (_isLoading)
    {
        <p class="text-muted">Loading child profile.</p>
    }
    else if (_parentId is null)
    {
        <div class="alert alert-info glass-panel">
            Configure your parent account in <a href="/settings">Settings</a> to manage deeds.
        </div>
    }
    else if (_child is null)
    {
        <div class="alert alert-warning glass-panel">
            Child not found. <a href="/children">Back to children</a>
        </div>
    }
    else
    {
        <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
            <div>
                <h2 class="fw-bold mb-1">@_child.Name</h2>
                <div class="text-muted">Reward rate $@(_child.DollarPerPoint.ToString("F2")) per point</div>
            </div>
            <button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("/children")'>Back to list</button>
        </div>

        <div class="row g-4">
            <div class="col-12 col-lg-5">
                <div class="card card-elevated mb-4">
                    <div class="card-body">
                        <h5 class="card-title">Balance</h5>
                        <p class="display-6 fw-bold @(BalanceClass)">@(_balance?.Points ?? 0) pts</p>
                        <p class="text-muted mb-0">$@((_balance?.Dollars ?? 0m).ToString("F2")) total value</p>
                    </div>
                </div>

                <div class="card card-elevated">
                    <div class="card-body">
                        <h5 class="card-title">Log a new deed</h5>
                        <EditForm Model="_form" OnValidSubmit="CreateDeedAsync">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label">Deed type</label>
                                @if (_deedTypes.Count == 0)
                                {
                                    @if (_deedTypesLoading)
                                    {
                                        <div class="text-muted small">Loading deed types...</div>
                                    }
                                    else
                                    {
                                        <div class="alert alert-warning">
                                            @if (_linkRequired)
                                            {
                                                <span>Your Microsoft sign-in is linked to a different parent. Link your legacy email in <a href="/settings">Settings</a> to load existing deed types.</span>
                                            }
                                            else
                                            {
                                                <span>No deed types available yet. Add them in <a href="/deeds">Deed Types</a>.</span>
                                            }
                                        </div>
                                    }
                                }
                                else
                                {
                                    <select class="form-select" @onchange="OnDeedTypeChanged">
                                        <option value="">Select a deed type</option>
                                        @foreach (var deedType in _deedTypes)
                                        {
                                            <option value="@deedType.Id" selected="@(deedType.Id == _form.DeedTypeId)">@deedType.Name (@(deedType.Points >= 0 ? "+" : string.Empty)@deedType.Points pts)</option>
                                        }
                                    </select>
                                }
                            </div>
                            @if (_deedTypesLoading)
                            {
                                <div class="text-muted small mb-3">Loading deed types.</div>
                            }
                            <div class="mb-3">
                                <label class="form-label">Condition or details</label>
                                <InputTextArea class="form-control" @bind-Value="_form.Condition" rows="2" placeholder="Describe the specific incident, e.g., 'Did it on first ask without complaining'" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Points (@(_form.Points >= 0 ? "+" : string.Empty)@_form.Points mins)</label>
                                <InputNumber class="form-control" @bind-Value="_form.Points" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Additional notes (optional)</label>
                                <InputTextArea class="form-control" @bind-Value="_form.Note" rows="2" />
                            </div>
                            <div class="d-flex gap-2 mb-3">
                                <button class="btn btn-primary flex-grow-1" type="submit" disabled="@(_isSubmitting || _form.DeedTypeId == Guid.Empty || _deedTypes.Count == 0)">@(_isSubmitting ? "Saving..." : "Add deed")</button>
                            </div>
                        </EditForm>
                        @if (!string.IsNullOrWhiteSpace(_feedback))
                        {
                            <div class="alert alert-warning mt-3">@_feedback</div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-7">
                <div class="card card-elevated">
                    <div class="card-body">
                        <h5 class="card-title">Deed history</h5>
                        @if (_deedsLoadError)
                        {
                            <div class="alert alert-warning">Unable to load deeds. @_deedsLoadErrorMessage</div>
                        }
                        @if (_deeds.Count == 0)
                        {
                            <p class="text-muted mb-0">No deeds logged yet. Add one using the form.</p>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var deed in _deeds)
                                {
                                    <div class="list-group-item">
                                        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                                            <div>
                                                <div class="fw-semibold">@DeedTypeName(deed.DeedTypeId)</div>
                                                <div class="small text-muted">@deed.OccurredAt.ToLocalTime().ToString("g")</div>
                                                @if (!string.IsNullOrWhiteSpace(deed.Note))
                                                {
                                                    <div class="mt-2">@deed.Note</div>
                                                }
                                            </div>
                                            <div class="text-end">
                                                <div class="fw-semibold @(deed.Points >= 0 ? "points-positive" : "points-negative")">
                                                    @(deed.Points >= 0 ? "+" : string.Empty)@deed.Points mins
                                                </div>
                                                <button class="btn btn-link text-danger p-0" @onclick='() => DeleteDeedAsync(deed.Id)'>Remove</button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        @if (_loadDurationMs.HasValue)
        {
            <div class="text-muted small mt-4">
                Page loaded in @_loadDurationMs.Value ms.
                @if (_debugTimings.Count > 0)
                {
                    <div class="mt-2">
                        @foreach (var entry in _debugTimings)
                        {
                            <div>@entry.Key: @entry.Value ms</div>
                        }
                    </div>
                }
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid ChildId { get; set; }

    private Guid? _parentId;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private ChildDto? _child;
    private BalanceDto? _balance;
    private AuthUser? _authUser;
    private readonly List<DeedDto> _deeds = [];
    private readonly List<DeedTypeDto> _deedTypes = [];
    private readonly DeedForm _form = new();
    private string? _feedback;
    private bool _authRefreshed;
    private bool _linkRequired;
    private bool _autoLinkAttempted;
    private bool _deedsLoadError;
    private string? _deedsLoadErrorMessage;
    private bool _deedTypesLoading;
    private bool _deedTypesLoaded;
    private long? _loadDurationMs;
    private Stopwatch? _loadTimer;
    private readonly Dictionary<string, long> _debugTimings = new();

    private string BalanceClass => (_balance?.Points ?? 0) >= 0 ? "points-positive" : "points-negative";

    protected override async Task OnInitializedAsync()
    {
        _authUser = await Auth.GetUserAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        _loadTimer = Stopwatch.StartNew();
        _loadDurationMs = null;
        _debugTimings.Clear();

        var parentTimer = Stopwatch.StartNew();
        _parentId = await ResolveParentIdAsync();
        parentTimer.Stop();
        _debugTimings["Resolve parent"] = parentTimer.ElapsedMilliseconds;
        if (_parentId is null)
        {
            _isLoading = false;
            _loadTimer.Stop();
            _loadDurationMs = _loadTimer.ElapsedMilliseconds;
            return;
        }

        await LoadAsync();
        if (!_deedTypesLoaded)
        {
            _ = LoadDeedTypesAsync();
        }

        _loadTimer.Stop();
        _loadDurationMs = _loadTimer.ElapsedMilliseconds;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        if (_authUser is null && !_authRefreshed)
        {
            _authRefreshed = true;
            await RefreshAuthAsync();
        }

        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _feedback = null;
        _deedsLoadError = false;
        _deedsLoadErrorMessage = null;
        _deeds.Clear();

        try
        {
            var parentId = _parentId!.Value;
            var childTask = ApiClient.GetChildAsync(ChildId, parentId);
            var balanceTask = ApiClient.GetChildBalanceAsync(ChildId, parentId);
            var deedsTask = ApiClient.GetDeedsForChildAsync(ChildId, parentId);

            var childAwaitTimer = Stopwatch.StartNew();
            _child = await childTask;
            childAwaitTimer.Stop();
            _debugTimings["Load child"] = childAwaitTimer.ElapsedMilliseconds;
            if (_child is null)
            {
                return;
            }

            try
            {
                var balanceAwaitTimer = Stopwatch.StartNew();
                _balance = await balanceTask;
                balanceAwaitTimer.Stop();
                _debugTimings["Load balance"] = balanceAwaitTimer.ElapsedMilliseconds;
            }
            catch (Exception balanceEx)
            {
                Console.WriteLine($"Error loading balance: {balanceEx.Message}");
            }

            try
            {
                var deedsAwaitTimer = Stopwatch.StartNew();
                _deeds.AddRange(await deedsTask);
                deedsAwaitTimer.Stop();
                _debugTimings["Load deeds"] = deedsAwaitTimer.ElapsedMilliseconds;
            }
            catch (Exception deedEx)
            {
                _deedsLoadError = true;
                _deedsLoadErrorMessage = deedEx.Message;
                Console.WriteLine($"Error loading deeds: {deedEx.Message}");
            }
        }
        catch (Exception ex)
        {
            _feedback = ex.Message;
            Console.WriteLine($"Error in LoadAsync: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadDeedTypesAsync()
    {
        if (_parentId is null || _deedTypesLoading)
        {
            return;
        }

        _deedTypesLoading = true;
        _deedTypesLoaded = false;
        _deedTypes.Clear();

        try
        {
            var parentId = _parentId.Value;
            var deedTypesTimer = Stopwatch.StartNew();
            _deedTypes.AddRange(await ApiClient.GetDeedTypesAsync(parentId));
            deedTypesTimer.Stop();
            _debugTimings["Load deed types"] = deedTypesTimer.ElapsedMilliseconds;
            _deedTypesLoaded = true;

            if (_deedTypes.Count > 0 && _form.DeedTypeId == Guid.Empty)
            {
                var first = _deedTypes.First();
                _form.DeedTypeId = first.Id;
                _form.Points = first.Points;
            }
            else if (_deedTypes.Count == 0 && _linkRequired)
            {
                _feedback = "Your Microsoft sign-in doesn't match the saved parent account. Link your existing parent email in Settings to access deed types.";
            }
        }
        catch (Exception deedTypeEx)
        {
            Console.WriteLine($"Error loading deed types: {deedTypeEx.Message}");
            _feedback = $"Could not load deed types: {deedTypeEx.Message}";
        }
        finally
        {
            _deedTypesLoading = false;
            StateHasChanged();
        }
    }

    private async Task RefreshAuthAsync()
    {
        Auth.ClearCache();
        _authUser = await Auth.GetUserAsync();
        _parentId = await ResolveParentIdAsync();
    }

    private async Task<Guid?> ResolveParentIdAsync()
    {
        var storedParent = await Settings.GetParentIdAsync();
        var storedEmail = await Settings.GetParentEmailAsync();

        try
        {
            var current = await ApiClient.GetCurrentParentAsync();
            if (current is not null)
            {
                _linkRequired = storedParent.HasValue && storedParent.Value != current.Id;
                if (_linkRequired && !_autoLinkAttempted && !string.IsNullOrWhiteSpace(storedEmail))
                {
                    _autoLinkAttempted = true;
                    try
                    {
                        var linked = await ApiClient.LinkParentAsync(storedEmail);
                        await Settings.SetParentIdAsync(linked.Id);
                        await Settings.SetParentEmailAsync(linked.Email);
                        _linkRequired = false;
                        return linked.Id;
                    }
                    catch (Exception linkEx)
                    {
                        Console.WriteLine($"Auto-link failed: {linkEx.Message}");
                    }
                }

                if (!storedParent.HasValue)
                {
                    await Settings.SetParentIdAsync(current.Id);
                    await Settings.SetParentEmailAsync(current.Email);
                }
                return current.Id;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error resolving current parent: {ex.Message}");
        }

        return storedParent;
    }

    private async Task CreateDeedAsync()
    {
        if (_form.DeedTypeId == Guid.Empty)
        {
            _feedback = "Select a deed type first.";
            return;
        }

        var resolvedParent = await ResolveParentIdAsync();
        if (resolvedParent is null)
        {
            _feedback = "Configure your parent account in Settings first.";
            return;
        }

        _parentId = resolvedParent;
        _isSubmitting = true;
        _feedback = null;
        string? note = _form.Condition;
        if (!string.IsNullOrWhiteSpace(_form.Note))
        {
            note = $"{_form.Condition}\n\n{_form.Note.Trim()}";
        }

        try
        {
            await ApiClient.CreateDeedAsync(_parentId.Value, ChildId, _form.DeedTypeId, _form.Points, note, ResolveCreatedBy());
            _form.Condition = string.Empty;
            _form.Note = string.Empty;
            if (_deedTypes.Count > 0)
            {
                _form.DeedTypeId = _deedTypes.First().Id;
                _form.Points = _deedTypes.First().Points;
            }
            await LoadAsync();
        }
        catch (Exception ex)
        {
            var message = ex.Message;
            if (message.Contains("ParentId", StringComparison.OrdinalIgnoreCase))
            {
                try
                {
                    var storedEmail = await Settings.GetParentEmailAsync();
                    if (!string.IsNullOrWhiteSpace(storedEmail))
                    {
                        var linked = await ApiClient.LinkParentAsync(storedEmail);
                        await Settings.SetParentIdAsync(linked.Id);
                        await Settings.SetParentEmailAsync(linked.Email);
                        _parentId = linked.Id;
                        await ApiClient.CreateDeedAsync(_parentId.Value, ChildId, _form.DeedTypeId, _form.Points, note, ResolveCreatedBy());
                        await LoadAsync();
                        return;
                    }
                }
                catch (Exception linkEx)
                {
                    message = linkEx.Message;
                }
            }

            _feedback = message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task DeleteDeedAsync(Guid deedId)
    {
        try
        {
            var resolvedParent = await ResolveParentIdAsync();
            if (resolvedParent is null)
            {
                _feedback = "Configure your parent account in Settings first.";
                return;
            }

            _parentId = resolvedParent;
            await ApiClient.DeleteDeedAsync(ChildId, deedId, _parentId.Value);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            var message = ex.Message;
            if (message.Contains("ParentId", StringComparison.OrdinalIgnoreCase))
            {
                try
                {
                    var storedEmail = await Settings.GetParentEmailAsync();
                    if (!string.IsNullOrWhiteSpace(storedEmail))
                    {
                        var linked = await ApiClient.LinkParentAsync(storedEmail);
                        await Settings.SetParentIdAsync(linked.Id);
                        await Settings.SetParentEmailAsync(linked.Email);
                        _parentId = linked.Id;
                        await ApiClient.DeleteDeedAsync(ChildId, deedId, _parentId.Value);
                        await LoadAsync();
                        return;
                    }
                }
                catch (Exception linkEx)
                {
                    message = linkEx.Message;
                }
            }

            _feedback = message;
        }
    }

    private string DeedTypeName(Guid deedTypeId)
    {
        return _deedTypes.FirstOrDefault(x => x.Id == deedTypeId)?.Name ?? "Deed";
    }

    private void OnDeedTypeChanged(ChangeEventArgs args)
    {
        if (Guid.TryParse(args.Value?.ToString(), out var deedTypeId))
        {
            _form.DeedTypeId = deedTypeId;
            var deedType = _deedTypes.FirstOrDefault(x => x.Id == deedTypeId);
            if (deedType is not null)
            {
                _form.Points = deedType.Points;
            }
        }
    }

    private sealed class DeedForm
    {
        public Guid DeedTypeId { get; set; }
        public string? Condition { get; set; }
        public int Points { get; set; }
        public string? Note { get; set; }
    }

    private string? ResolveCreatedBy()
        => _authUser?.DisplayName ?? _authUser?.Email ?? _parentId?.ToString();
}
