@page "/deeds"

@inject ApiClient ApiClient
@inject ChatGptService ChatGpt
@inject UserSettingsService Settings

<PageTitle>Deed Types</PageTitle>

<div class="page">
    <h2 class="fw-bold mb-3">Deed Types</h2>
    <p class="text-muted">Create deed templates with positive or negative points, then reuse them when logging deeds for each child.</p>

    @if (_isLoading)
    {
        <div class="text-muted">Loading deed types.</div>
    }
    else if (_parentId is null)
    {
        <div class="alert alert-info glass-panel">
            Configure your parent account in <a href="/settings">Settings</a> first.
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-12 col-lg-7">
                <div class="card card-elevated">
                    <div class="card-body">
                        <h5 class="card-title">Saved deed types</h5>
                        @if (_deedTypes.Count == 0)
                        {
                            <p class="text-muted mb-0">No deed types yet. Add your first one using the form.</p>
                        }
                        else
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var deed in _deedTypes)
                                {
                                    <div class="list-group-item d-flex flex-wrap justify-content-between align-items-center gap-3">
                                        <div>
                                            <div class="fw-semibold">@deed.Name</div>
                                            <span class="badge @(deed.Points >= 0 ? "badge-good" : "badge-bad")">@(deed.Points >= 0 ? "Good" : "Bad") deed</span>
                                        </div>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="fw-semibold @(deed.Points >= 0 ? "points-positive" : "points-negative")">
                                                @(deed.Points >= 0 ? "+" : string.Empty)@deed.Points pts
                                            </div>
                                            <button class="btn btn-link text-danger" @onclick='() => DeleteDeedTypeAsync(deed.Id)'>Remove</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="card card-elevated">
                    <div class="card-body">
                        <h5 class="card-title">Add a deed type</h5>
                        <EditForm Model="_form" OnValidSubmit="CreateDeedTypeAsync">
                            <DataAnnotationsValidator />
                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <InputText class="form-control" @bind-Value="_form.Name" />
                            </div>
                            <div class="mb-3">
                                <h6 class="mb-2">AI points suggestion</h6>
                                <p class="text-muted small mb-2">Describe the situation to get a suggested point adjustment for this new deed.</p>
                                <label class="form-label">Condition or details (optional)</label>
                                <InputTextArea class="form-control" @bind-Value="_suggestCondition" rows="3" placeholder="Describe the specific incident (optional)" />
                                <button class="btn btn-outline-secondary w-100 mt-3" type="button" @onclick="SuggestPointsAsync" disabled="@(_suggesting || string.IsNullOrWhiteSpace(_form.Name))">
                                    @(_suggesting ? "Contacting AI..." : "Suggest points")
                                </button>
                                @if (!string.IsNullOrWhiteSpace(_suggestFeedback))
                                {
                                    <div class="alert alert-warning mt-3">@_suggestFeedback</div>
                                }
                                @if (_suggestedPoints.HasValue)
                                {
                                    <div class="alert alert-info mt-3">
                                        <div class="fw-semibold">Suggested points: @_suggestedPoints.Value</div>
                                        @if (!string.IsNullOrWhiteSpace(_suggestionReason))
                                        {
                                            <div class="text-muted small">@_suggestionReason</div>
                                        }
                                    </div>
                                }
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Deed nature</label>
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="kind" id="good" checked="@_form.IsGood" @onchange="() => SetGood(true)" />
                                    <label class="btn btn-outline-success" for="good">Good deed</label>
                                    <input type="radio" class="btn-check" name="kind" id="bad" checked="@(!_form.IsGood)" @onchange="() => SetGood(false)" />
                                    <label class="btn btn-outline-danger" for="bad">Bad deed</label>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Points</label>
                                <InputNumber class="form-control" @bind-Value="_form.Points" />
                                <div class="form-text">Positive points reward a good deed; negative points penalise a bad one.</div>
                            </div>
                            <button class="btn btn-primary w-100" type="submit" disabled="@_isSubmitting">@(_isSubmitting ? "Saving..." : "Create deed type")</button>
                        </EditForm>
                        @if (!string.IsNullOrWhiteSpace(_feedback))
                        {
                            <div class="alert alert-warning mt-3">@_feedback</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private Guid? _parentId;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private readonly List<DeedTypeDto> _deedTypes = [];
    private readonly DeedTypeForm _form = new();
    private string? _feedback;
    private bool _autoLinkAttempted;
    private string _suggestCondition = string.Empty;
    private bool _suggesting;
    private int? _suggestedPoints;
    private string? _suggestionReason;
    private string? _suggestFeedback;

    protected override async Task OnInitializedAsync()
    {
        _parentId = await ResolveParentIdAsync();
        if (_parentId is null)
        {
            _isLoading = false;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _isLoading = true;
        _feedback = null;
        _deedTypes.Clear();

        try
        {
            _deedTypes.AddRange(await ApiClient.GetDeedTypesAsync(_parentId!.Value));
        }
        catch (Exception ex)
        {
            _feedback = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CreateDeedTypeAsync()
    {
        if (_parentId is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _feedback = "Name is required";
            return;
        }

        if (_form.Points == 0)
        {
            _feedback = "Points cannot be zero";
            return;
        }

        _isSubmitting = true;
        _feedback = null;

        try
        {
            var points = _form.IsGood ? Math.Abs(_form.Points) : -Math.Abs(_form.Points);
            await ApiClient.CreateDeedTypeAsync(_parentId.Value, _form.Name.Trim(), points);
            _form.Reset();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _feedback = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private async Task DeleteDeedTypeAsync(Guid deedTypeId)
    {
        if (_parentId is null)
        {
            return;
        }

        try
        {
            await ApiClient.DeleteDeedTypeAsync(_parentId.Value, deedTypeId);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _feedback = ex.Message;
        }
    }

    private void SetGood(bool isGood)
    {
        _form.IsGood = isGood;
        if (_form.Points < 0 && isGood)
        {
            _form.Points = Math.Abs(_form.Points);
        }
        else if (_form.Points > 0 && !isGood)
        {
            _form.Points = -Math.Abs(_form.Points);
        }
    }

    private async Task SuggestPointsAsync()
    {
        if (string.IsNullOrWhiteSpace(_form.Name))
        {
            _suggestFeedback = "Enter a deed name first.";
            return;
        }

        _suggesting = true;
        _suggestFeedback = null;
        _suggestedPoints = null;
        _suggestionReason = null;

        try
        {
            var suggestion = await ChatGpt.SuggestPointsForConditionAsync(_form.Name, _suggestCondition, _form.IsGood);
            if (suggestion is null)
            {
                _suggestFeedback = "AI could not suggest points right now. Try again.";
                return;
            }

            _suggestedPoints = suggestion.Points;
            _suggestionReason = suggestion.Reason;
        }
        catch (Exception ex)
        {
            _suggestFeedback = ex.Message;
        }
        finally
        {
            _suggesting = false;
        }
    }

    private async Task<Guid?> ResolveParentIdAsync()
    {
        var storedParent = await Settings.GetParentIdAsync();
        var storedEmail = await Settings.GetParentEmailAsync();
        try
        {
            var current = await ApiClient.GetCurrentParentAsync();
            if (current is not null)
            {
                if (storedParent.HasValue && storedParent.Value != current.Id && !_autoLinkAttempted && !string.IsNullOrWhiteSpace(storedEmail))
                {
                    _autoLinkAttempted = true;
                    try
                    {
                        var linked = await ApiClient.LinkParentAsync(storedEmail);
                        await Settings.SetParentIdAsync(linked.Id);
                        await Settings.SetParentEmailAsync(linked.Email);
                        return linked.Id;
                    }
                    catch (Exception linkEx)
                    {
                        Console.WriteLine($"Auto-link failed: {linkEx.Message}");
                    }
                }

                if (!storedParent.HasValue)
                {
                    await Settings.SetParentIdAsync(current.Id);
                    await Settings.SetParentEmailAsync(current.Email);
                }
                return current.Id;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error resolving current parent: {ex.Message}");
        }

        return storedParent;
    }

    private sealed class DeedTypeForm
    {
        public string Name { get; set; } = string.Empty;
        public bool IsGood { get; set; } = true;
        public int Points { get; set; } = 5;

        public void Reset()
        {
            Name = string.Empty;
            IsGood = true;
            Points = 5;
        }
    }
}
