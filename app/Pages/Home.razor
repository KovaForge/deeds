@page "/"

@inject ApiClient ApiClient
@inject AuthService Auth
@inject UserSettingsService Settings
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Dashboard</PageTitle>

<div class="page">
	<div class="d-flex flex-wrap gap-3 align-items-center justify-content-between mb-4">
		<div>
			<div class="step-label mb-2">Family Rewards</div>
			<h1 class="fw-bold mb-2">Dashboard</h1>
			<p class="text-muted mb-0">
				Track good deeds, adjust points quickly, and keep every child focused on what matters.
			</p>
			@if (_authUser is null)
			{
				<div class="card card-elevated mt-3">
					<div class="card-body">
						<h5 class="card-title">Getting started</h5>
						<div class="stack">
							<div>
								<div class="step-label mb-1">Step 1</div>
								<div class="fw-semibold">Add your children</div>
								<div class="text-muted small">Set point values and reward rates in minutes.</div>
							</div>
							<div>
								<div class="step-label mb-1">Step 2</div>
								<div class="fw-semibold">Log a deed</div>
								<div class="text-muted small">Track progress and balances instantly.</div>
							</div>
						</div>
					</div>
				</div>
			}
		</div>
		<div class="d-flex gap-2 flex-wrap">
		</div>
	</div>

	<div class="row g-4 mb-4">
		<div class="col-12">
			<div class="card card-elevated h-100">
				<div class="card-body">
					<h5 class="card-title">Sign in with Microsoft</h5>
					<p class="text-muted">Use your Microsoft account to sync settings and keep your family data secure.</p>
					@if (_authUser is null)
					{
						<a class="btn btn-primary w-100 mb-3" href="@LoginUrl">Continue with Microsoft</a>
						<div class="text-muted small">Already have a parent email saved? Link it in <a href="settings">Settings</a> after signing in.</div>
					}
					else
					{
						<div class="alert alert-success">Signed in as @_authUser.DisplayName</div>
						<button class="btn btn-outline-secondary w-100" @onclick='() => Navigation.NavigateTo("settings")'>Manage linked account</button>
					}
				</div>
			</div>
		</div>
	</div>

		@if (_isLoading)
		{
			<div class="content-section text-center text-muted">Loading dashboard.</div>
		}
		else if (_parentId is null)
		{
			<div class="content-section">
				<div class="card card-elevated">
					<div class="card-body">
						<h5 class="fw-semibold mb-2">You're almost ready</h5>
						<p class="text-muted mb-3">Connect your parent account to load children, deeds, and balances.</p>
						<div class="d-flex flex-wrap gap-2">
							<button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("settings")'>Open settings</button>
							@if (_authUser is null)
							{
								<a class="btn btn-outline-secondary" href="@LoginUrl">Sign in with Microsoft</a>
							}
						</div>
					</div>
				</div>
			</div>
		}
		else if (_loadError)
		{
			<div class="content-section">
				<div class="card card-elevated">
					<div class="card-body">
						<h5 class="fw-semibold mb-2">We couldn't load your dashboard yet</h5>
						<p class="text-muted mb-3">
							@(_linkRequired
								? "Your Microsoft sign-in doesn't match the saved parent account. Link your existing parent email in Settings."
								: "Finish signing in and try again in a moment.")
						</p>
						<div class="d-flex flex-wrap gap-2">
							<button class="btn btn-primary" @onclick="LoadDashboardAsync">Retry loading</button>
							@if (_linkRequired)
							{
								<button class="btn btn-outline-secondary" @onclick='() => Navigation.NavigateTo("settings")'>Open settings</button>
							}
						</div>
					</div>
				</div>
			</div>
		}
		else if (_children.Count == 0)
		{
			<div class="content-section">
				<div class="card card-elevated text-center">
					<div class="card-body">
						<h5 class="fw-semibold mb-2">No children added yet</h5>
						<p class="text-muted">Add your first child to start tracking deeds and balances.</p>
						<button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("children")'>Add a Child</button>
					</div>
				</div>
			</div>
		}
		else
		{
			<div class="content-section">
				<div class="row g-4">
					<div class="col-12">
						<div class="card card-elevated h-100">
							<div class="card-body">
								<h5 class="card-title">Children Snapshot</h5>
								<div class="list-group list-group-flush">
									@foreach (var child in _children)
									{
										<button class="list-group-item list-group-item-action d-flex justify-content-between align-items-center" @onclick='() => Navigation.NavigateTo($"children/{child.Id}")'>
											<div>
												<div class="fw-semibold">@child.Name</div>
												<small class="text-muted">@child.DeedsCount deed(s) logged</small>
											</div>
											<div class="text-end">
												<div class="fw-semibold @(child.Points >= 0 ? "points-positive" : "points-negative")">@child.Points pts</div>
												<small class="text-muted">$@child.Dollars.ToString("F2")</small>
											</div>
										</button>
									}
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		}
</div>

@code {
	private Guid? _parentId;
	private AuthUser? _authUser;
	private bool _isLoading = true;
	private bool _loadError;
	private bool _linkRequired;
	private string? _loadErrorMessage;
	private bool _dataRefreshAttempted;
	private readonly List<ChildSummary> _children = [];
	private bool _authRefreshed;
	private bool _autoLinkAttempted;
	private readonly SemaphoreSlim _loadGate = new(1, 1);

    protected override async Task OnInitializedAsync()
    {
        Auth.UserChanged += OnAuthChanged;
        _authUser = await Auth.GetUserAsync();
        _parentId = await ResolveParentIdAsync();
        await LoadDashboardAsync();
    }

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender || _authRefreshed)
		{
			return;
		}

		_authRefreshed = true;
		await RefreshAuthAsync();
	}

    private async Task RefreshAuthAsync()
    {
        Auth.ClearCache();
        var latest = await Auth.GetUserAsync();
        if (!Equals(latest, _authUser))
        {
            _authUser = latest;
            StateHasChanged();
        }
        _parentId = await ResolveParentIdAsync();

        if (_parentId is not null && !_dataRefreshAttempted && (_children.Count == 0 || _loadError))
        {
            _dataRefreshAttempted = true;
            await LoadDashboardAsync();
            StateHasChanged();
        }
    }

    private void OnAuthChanged()
    {
        _ = InvokeAsync(async () =>
        {
            _authUser = await Auth.GetUserAsync();
            StateHasChanged();
        });
    }

    private async Task LoadDashboardAsync()
    {
        await _loadGate.WaitAsync();
        try
        {
            if (_parentId is null)
            {
                _isLoading = false;
                _loadError = false;
                return;
            }

            _isLoading = true;
            _loadError = false;
            _linkRequired = false;
            _loadErrorMessage = null;
            _children.Clear();
            try
            {
                var children = await ApiClient.GetChildrenAsync(_parentId.Value);
                var seenChildIds = new HashSet<Guid>();
                foreach (var child in children)
                {
                    if (!seenChildIds.Add(child.Id))
                    {
                        continue;
                    }

                    BalanceDto? balance = null;
                    IReadOnlyList<DeedDto> deeds = Array.Empty<DeedDto>();

                    try
                    {
                        balance = await ApiClient.GetChildBalanceAsync(child.Id, _parentId.Value);
                    }
                    catch (Exception balanceEx)
                    {
                        Console.WriteLine($"Dashboard balance error: {balanceEx.Message}");
                    }

                    try
                    {
                        deeds = await ApiClient.GetDeedsForChildAsync(child.Id, _parentId.Value);
                    }
                    catch (Exception deedEx)
                    {
                        Console.WriteLine($"Dashboard deeds error: {deedEx.Message}");
                    }

                    var points = balance?.Points ?? 0;
                    var dollars = balance?.Dollars ?? 0m;
                    _children.Add(new ChildSummary(child.Id, child.Name, points, dollars, deeds.Count));
                }
            }
            catch (Exception ex)
            {
                _loadError = true;
                _loadErrorMessage = ex.Message;
                if (ex.Message.Contains("ParentId does not match authenticated user", StringComparison.OrdinalIgnoreCase))
                {
                    _linkRequired = true;
                }
                Console.WriteLine($"Dashboard error: {ex.Message}");
            }
            finally
            {
                _isLoading = false;
            }
        }
        finally
        {
            _loadGate.Release();
        }
    }

    private async Task<Guid?> ResolveParentIdAsync()
    {
        var storedParent = await Settings.GetParentIdAsync();
        var storedEmail = await Settings.GetParentEmailAsync();

        try
        {
            var current = await ApiClient.GetCurrentParentAsync();
            if (current is not null)
            {
                _linkRequired = storedParent.HasValue && storedParent.Value != current.Id;
                if (_linkRequired && !_autoLinkAttempted && !string.IsNullOrWhiteSpace(storedEmail))
                {
                    _autoLinkAttempted = true;
                    try
                    {
                        var linked = await ApiClient.LinkParentAsync(storedEmail);
                        await Settings.SetParentIdAsync(linked.Id);
                        await Settings.SetParentEmailAsync(linked.Email);
                        _linkRequired = false;
                        return linked.Id;
                    }
                    catch (Exception linkEx)
                    {
                        Console.WriteLine($"Auto-link failed: {linkEx.Message}");
                    }
                }

                if (!storedParent.HasValue)
                {
                    await Settings.SetParentIdAsync(current.Id);
                    await Settings.SetParentEmailAsync(current.Email);
                }
                return current.Id;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error resolving current parent: {ex.Message}");
        }

        return storedParent;
    }

	private sealed record ChildSummary(Guid Id, string Name, int Points, decimal Dollars, int DeedsCount);

	private string LoginUrl => $"/.auth/login/aad?post_login_redirect_uri={Uri.EscapeDataString(ReturnPath)}";

	private string ReturnPath
	{
		get
		{
			var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
			if (string.IsNullOrWhiteSpace(relative))
			{
				return "/";
			}

			return relative.StartsWith('/') ? relative : $"/{relative}";
		}
	}

    public void Dispose()
    {
        Auth.UserChanged -= OnAuthChanged;
    }
}
