@page "/settings"

@inject ApiClient ApiClient
@inject AuthService Auth
@inject NavigationManager Navigation
@inject UserSettingsService UserSettings

<PageTitle>Settings</PageTitle>

<h2 class="fw-bold mb-3">Settings</h2>
<p class="text-muted">Connect your parent account and manage AI suggestions.</p>

<div class="row g-4">
    <div class="col-12 col-lg-6">
        <div class="card card-elevated">
            <div class="card-body">
                <h5 class="card-title">Parent account</h5>
                <p class="text-muted">We use this parent ID for every API call. Creating or linking a parent happens in your Azure Functions backend.</p>

                <div class="alert alert-light border d-flex align-items-center justify-content-between flex-wrap gap-2">
                    <div>
                        <div class="fw-semibold">Microsoft sign-in</div>
                        @if (_authUser is null)
                        {
                            <div class="text-muted small">Not signed in. Sign in to auto-link your parent account.</div>
                        }
                        else
                        {
                            <div class="text-muted small">Signed in as @_authUser.DisplayName (@(_authUser.Email ?? _authUser.UserDetails)).</div>
                        }
                    </div>
                    <div class="d-flex gap-2">
                        @if (_authUser is null)
                        {
                            <a class="btn btn-outline-primary btn-sm" href="@LoginUrl">Sign in</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-primary btn-sm" type="button" @onclick="LinkSignedInParentAsync" disabled="@_savingParent">Link this account</button>
                            <a class="btn btn-outline-secondary btn-sm" href="@LogoutUrl">Sign out</a>
                        }
                    </div>
                </div>

                <EditForm Model="_parentForm" OnValidSubmit="SaveParentAsync">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">Parent email</label>
                        <InputText class="form-control" @bind-Value="_parentForm.Email" />
                        <div class="form-text">Use the same email each time to reconnect to the same parent.</div>
                    </div>
                    <button type="submit" class="btn btn-primary" disabled="@_savingParent">@(_savingParent ? "Saving." : "Save parent")</button>
                    @if (_hasStoredParent)
                    {
                        <button type="button" class="btn btn-outline-danger ms-2" @onclick="ClearParentAsync">Forget parent</button>
                    }
                </EditForm>

                @if (_parentFeedback is not null)
                {
                    <div class="alert alert-info mt-3">@_parentFeedback</div>
                }

                @if (_currentParent is not null)
                {
                    <div class="alert alert-success mt-3">
                        <div class="fw-semibold">Parent linked</div>
                        <div>Email: @_currentParent.Email</div>
                        <div>ID: @_currentParent.Id</div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-6">
        <div class="card card-elevated">
            <div class="card-body">
                <h5 class="card-title">AI suggestions</h5>
                <p class="text-muted">Store your OpenAI key securely for your account. The key is encrypted server-side and never stored in your browser.</p>

                <EditForm Model="_aiKeyForm" OnValidSubmit="SaveAiKeyAsync">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <label class="form-label">OpenAI API key</label>
                        <InputText class="form-control" @bind-Value="_aiKeyForm.ApiKey" type="password" />
                        <div class="form-text">Your key is encrypted with the app's encryption key.</div>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary" type="submit" disabled="@(_savingAiKey || _authUser is null)">@(_savingAiKey ? "Saving." : "Save key")</button>
                        <button class="btn btn-outline-danger" type="button" disabled="@(!_hasAiKey || _savingAiKey || _authUser is null)" @onclick="ClearAiKeyAsync">Clear key</button>
                    </div>
                </EditForm>

                @if (_aiKeyFeedback is not null)
                {
                    <div class="alert alert-info mt-3">@_aiKeyFeedback</div>
                }

                @if (_hasAiKey)
                {
                    <div class="alert alert-success mt-3">AI key stored for this account.</div>
                }
                else
                {
                    <div class="alert alert-warning mt-3">No AI key stored yet.</div>
                }
            </div>
        </div>
    </div>
</div>

@if (ShowLinkPrompt)
{
    <div class="card card-elevated mt-4">
        <div class="card-body">
            <h5 class="card-title">Link existing account</h5>
            <p class="text-muted">Your Microsoft sign-in email doesn't match the parent email already saved in this browser. Enter the existing parent email to link it.</p>
            <EditForm Model="_linkForm" OnValidSubmit="LinkExistingParentAsync">
                <DataAnnotationsValidator />
                <div class="mb-3">
                    <label class="form-label">Existing parent email</label>
                    <InputText class="form-control" @bind-Value="_linkForm.Email" />
                    <div class="form-text">Example: the email you used before signing in (e.g., mike@delpach.com).</div>
                </div>
                <button class="btn btn-primary" type="submit" disabled="@_linkingParent">@(_linkingParent ? "Linking." : "Link account")</button>
            </EditForm>
            @if (_linkFeedback is not null)
            {
                <div class="alert alert-info mt-3">@_linkFeedback</div>
            }
        </div>
    </div>
}

@code {
    private readonly ParentForm _parentForm = new();
    private readonly AiKeyForm _aiKeyForm = new();
    private readonly LinkForm _linkForm = new();

    private AuthUser? _authUser;
    private ParentDto? _currentParent;
    private bool _hasStoredParent;
    private bool _savingParent;
    private bool _savingAiKey;
    private bool _hasAiKey;
    private string? _parentFeedback;
    private string? _aiKeyFeedback;
    private bool _linkingParent;
    private string? _linkFeedback;

    protected override async Task OnInitializedAsync()
    {
        _authUser = await Auth.GetUserAsync();
        var parentId = await UserSettings.GetParentIdAsync();
        if (parentId is not null)
        {
            _hasStoredParent = true;
            _currentParent = await ApiClient.GetParentAsync(parentId.Value);
            if (_currentParent is not null)
            {
                _parentForm.Email = _currentParent.Email;
                _linkForm.Email = _currentParent.Email;
            }
        }
        else if (string.IsNullOrWhiteSpace(_parentForm.Email) && _authUser?.Email is not null)
        {
            _parentForm.Email = _authUser.Email;
        }

        if (_authUser is not null)
        {
            await LoadAiKeyStatusAsync();
        }
    }

    private async Task SaveParentAsync()
    {
        if (string.IsNullOrWhiteSpace(_parentForm.Email))
        {
            _parentFeedback = "Email is required";
            return;
        }

        _savingParent = true;
        _parentFeedback = null;

        try
        {
            var email = _parentForm.Email.Trim().ToLowerInvariant();
            ParentDto parent;
            if (_authUser is not null && !EmailsMatch(email, _authUser.Email))
            {
                parent = await ApiClient.LinkParentAsync(email);
                _parentFeedback = "Existing parent linked to your Microsoft sign-in.";
            }
            else
            {
                try
                {
                    parent = await ApiClient.CreateParentAsync(email);
                }
                catch (Exception ex)
                {
                    var existing = await ApiClient.FindParentByEmailAsync(email);
                    if (existing is null)
                    {
                        throw new InvalidOperationException(ex.Message);
                    }

                    parent = existing;
                    _parentFeedback = "Existing parent linked.";
                }
            }

            _currentParent = parent;
            await UserSettings.SetParentIdAsync(parent.Id);
            _hasStoredParent = true;
            _linkForm.Email = parent.Email;
            _parentFeedback ??= "Parent saved.";
        }
        catch (Exception ex)
        {
            _parentFeedback = ex.Message;
        }
        finally
        {
            _savingParent = false;
        }
    }

    private async Task ClearParentAsync()
    {
        await UserSettings.ClearParentIdAsync();
        _hasStoredParent = false;
        _currentParent = null;
        _parentFeedback = "Parent removed from this browser.";
    }

    private async Task LinkSignedInParentAsync()
    {
        if (_authUser is null)
        {
            _parentFeedback = "Sign in with Microsoft to link your parent account.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_authUser.Email))
        {
            _parentFeedback = "Your Microsoft profile did not include an email address. Enter one manually.";
            return;
        }

        _parentForm.Email = _authUser.Email;
        await SaveParentAsync();
    }

    private async Task LinkExistingParentAsync()
    {
        if (_authUser is null)
        {
            _linkFeedback = "Sign in with Microsoft to link an existing account.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_linkForm.Email))
        {
            _linkFeedback = "Existing parent email is required.";
            return;
        }

        _linkingParent = true;
        _linkFeedback = null;

        try
        {
            var email = _linkForm.Email.Trim().ToLowerInvariant();
            var parent = await ApiClient.LinkParentAsync(email);
            _currentParent = parent;
            await UserSettings.SetParentIdAsync(parent.Id);
            _hasStoredParent = true;
            _parentForm.Email = parent.Email;
            _linkFeedback = "Account linked successfully.";
        }
        catch (Exception ex)
        {
            _linkFeedback = ex.Message;
        }
        finally
        {
            _linkingParent = false;
        }
    }

    private async Task LoadAiKeyStatusAsync()
    {
        try
        {
            var status = await ApiClient.GetAiKeyStatusAsync();
            _hasAiKey = status.HasKey;
        }
        catch (Exception ex)
        {
            _aiKeyFeedback = ex.Message;
        }
    }

    private async Task SaveAiKeyAsync()
    {
        if (_authUser is null)
        {
            _aiKeyFeedback = "Sign in with Microsoft to save your AI key.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_aiKeyForm.ApiKey))
        {
            _aiKeyFeedback = "API key is required.";
            return;
        }

        _savingAiKey = true;
        _aiKeyFeedback = null;

        try
        {
            await ApiClient.SetAiKeyAsync(_aiKeyForm.ApiKey.Trim());
            _aiKeyForm.ApiKey = string.Empty;
            _hasAiKey = true;
            _aiKeyFeedback = "AI key saved.";
        }
        catch (Exception ex)
        {
            _aiKeyFeedback = ex.Message;
        }
        finally
        {
            _savingAiKey = false;
        }
    }

    private async Task ClearAiKeyAsync()
    {
        if (_authUser is null)
        {
            _aiKeyFeedback = "Sign in with Microsoft to manage your AI key.";
            return;
        }

        _savingAiKey = true;
        _aiKeyFeedback = null;

        try
        {
            await ApiClient.ClearAiKeyAsync();
            _hasAiKey = false;
            _aiKeyFeedback = "AI key removed.";
        }
        catch (Exception ex)
        {
            _aiKeyFeedback = ex.Message;
        }
        finally
        {
            _savingAiKey = false;
        }
    }

    private sealed class ParentForm
    {
        public string Email { get; set; } = string.Empty;
    }

    private sealed class AiKeyForm
    {
        public string ApiKey { get; set; } = string.Empty;
    }

    private sealed class LinkForm
    {
        public string Email { get; set; } = string.Empty;
    }

    private bool ShowLinkPrompt
        => _authUser is not null
           && _currentParent is not null
           && !EmailsMatch(_currentParent.Email, _authUser.Email);

    private static bool EmailsMatch(string? left, string? right)
        => string.Equals(left?.Trim(), right?.Trim(), StringComparison.OrdinalIgnoreCase);

    private string LoginUrl => $"/.auth/login/aad?post_login_redirect_uri={Uri.EscapeDataString(ReturnPath)}";

    private string LogoutUrl => $"/.auth/logout?post_logout_redirect_uri={Uri.EscapeDataString(ReturnPath)}";

    private string ReturnPath
    {
        get
        {
            var relative = Navigation.ToBaseRelativePath(Navigation.Uri);
            if (string.IsNullOrWhiteSpace(relative))
            {
                return "/";
            }

            return relative.StartsWith('/') ? relative : $"/{relative}";
        }
    }
}
